{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executable-path=/etc/profiles/per-user/christopher/bin/chromium",
      ]
    },
    "lucid": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.lucid.app/mcp"]
    },
    "github": {
      "enabled": true ,
      "oauth": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "mobile-mcp": {
      "type": "local",
      "command": [
        "npx",
        "@mobilenext/mobile-mcp@latest"
      ],
      "enabled": true
    }
  },
  "plugin": [],
  "provider": {
    "anthropic": {
      "options": {}
    },
    "openrouter": {
      "models": {}
    }
  }
}
